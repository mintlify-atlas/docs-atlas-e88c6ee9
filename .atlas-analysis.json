  "keyFeatures": [
    "Offline-first architecture — all edits work without an internet connection using a local database",
    "Rich text editor with bold, italic, underline, headings, lists, and checkboxes",
    "Cross-device sync — changes propagate automatically when back online",
    "Note sharing with viewer or editor permissions",
    "Tags system with custom names and colors",
    "Customizable note backgrounds (solid colors and patterns)",
    "Pin, archive, and trash notes with recovery support",
    "Full-text search by title or content",
    "Admin panel for user management, registration control, and system stats",
    "OIDC authentication (Pocket ID, Authelia, Authentik, Keycloak, etc.)",
    "Self-hostable via a single Docker container with embedded database"
  ],
